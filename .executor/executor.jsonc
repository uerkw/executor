{
  "sources": {
    "google-gmail": {
      "kind": "google_discovery",
      "name": "Gmail",
      "namespace": "google.gmail",
      "connection": {
        "endpoint": "https://gmail.googleapis.com/$discovery/rest?version=v1"
      },
      "binding": {
        "service": "gmail",
        "version": "v1",
        "discoveryUrl": "https://gmail.googleapis.com/$discovery/rest?version=v1",
        "defaultHeaders": null,
        "scopes": []
      }
    }
  }
}
