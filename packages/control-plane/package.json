{
  "name": "@executor-v3/control-plane",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./schema": "./src/schema/index.ts"
  },
  "imports": {
    "#schema": "./src/schema/index.ts",
    "#domain": "./src/domain/index.ts",
    "#persistence": "./src/persistence/index.ts",
    "#api": "./src/api/index.ts",
    "#runtime": "./src/runtime/index.ts"
  },
  "scripts": {
    "typecheck": "bunx tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "bunx drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "bunx drizzle-kit migrate --config drizzle.config.ts",
    "db:studio": "bunx drizzle-kit studio --config drizzle.config.ts"
  },
  "dependencies": {
    "@effect/platform": "catalog:",
    "@electric-sql/pglite": "^0.3.12",
    "@executor-v3/codemode-core": "workspace:*",
    "@executor-v3/codemode-mcp": "workspace:*",
    "@executor-v3/codemode-openapi": "workspace:*",
    "@executor-v3/runtime-local-inproc": "workspace:*",
    "drizzle-orm": "1.0.0-beta.15-859cf75",
    "effect": "catalog:",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "@effect/platform-node": "catalog:",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "bun-types": "catalog:",
    "drizzle-kit": "1.0.0-beta.15-859cf75",
    "vitest": "catalog:",
    "zod": "catalog:"
  }
}
