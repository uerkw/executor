{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"],
    "types": ["bun-types", "node"],
    "noUnusedLocals": true,
    "noImplicitOverride": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "@effect/language-service",
        "diagnosticSeverity": {
          "globalErrorInEffectFailure": "off"
        }
      }
    ]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "src/promise.ts",
    "src/sdk/presets.ts",
    "src/sdk/config-file-store.ts"
  ]
}
