{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["ES2022", "DOM"],
    "types": ["bun-types", "node"],
    "noUnusedLocals": true,
    "noImplicitOverride": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "@effect/language-service",
        "diagnostics": {
          "preferSchemaOverJson": "off"
        }
      }
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ]
}
