---
import Layout from '../layouts/Layout.astro'

const heroCode = `<span class="text-ink-faint">// discover by intent, call with types</span>
<span class="text-teal">const</span> matches = <span class="text-teal">await</span> tools.<span class="text-ink">discover</span>({
  query: <span class="text-emerald-400">"github issues"</span>
})

<span class="text-teal">const</span> issues = <span class="text-teal">await</span> tools.github.issues.<span class="text-ink">list</span>({
  owner: <span class="text-emerald-400">"vercel"</span>,
  repo: <span class="text-emerald-400">"next.js"</span>
})<span class="cursor-blink text-teal">_</span>`

const mcpCode = `<span class="text-ink-muted">$</span> executor mcp --stdio
<span class="text-ink-faint">  482 tools · policies active · auth shared</span>`
---

<Layout>
  <!-- ─── NAV ─── -->
  <nav class="fixed top-0 w-full z-50 bg-surface/80 backdrop-blur-lg">
    <div class="max-w-[1200px] mx-auto px-6 sm:px-10 h-14 flex items-center justify-between border-b border-rule">
      <a href="/" class="font-display text-xl italic text-ink tracking-tight hover:text-teal transition-colors">executor</a>
      <div class="flex items-center gap-8">
        <a href="#how-it-works" class="hidden sm:block text-[13px] text-ink-muted hover:text-ink transition-colors">How it works</a>
        <a href="#roadmap" class="hidden sm:block text-[13px] text-ink-muted hover:text-ink transition-colors">Roadmap</a>
        <a href="https://github.com/RhysSullivan/executor" class="hidden sm:block text-[13px] text-ink-muted hover:text-ink transition-colors">GitHub</a>
        <a href="https://github.com/RhysSullivan/executor" class="text-[13px] font-medium text-surface bg-teal hover:bg-teal-dim px-4 py-1.5 rounded-md transition-colors">
          Get started
        </a>
      </div>
    </div>
  </nav>

  <!-- ─── HERO ─── -->
  <section class="relative min-h-screen flex flex-col justify-center pt-14 overflow-hidden">
    <div class="absolute top-[15%] right-[10%] w-[500px] h-[500px] bg-teal/[0.04] rounded-full blur-[150px] pointer-events-none"></div>

    <div class="max-w-[1200px] mx-auto px-6 sm:px-10 w-full">
      <div class="grid lg:grid-cols-[1fr,minmax(0,480px)] gap-12 lg:gap-20 items-center py-20 lg:py-0">
        <div>
          <div class="rise flex items-center gap-3 mb-10">
            <div class="h-px flex-1 max-w-12 bg-teal/40"></div>
            <span class="text-[11px] font-mono uppercase tracking-[0.2em] text-teal">Now in beta</span>
          </div>

          <h1 class="rise-d1 font-display text-[clamp(3rem,7vw,5.5rem)] leading-[0.95] tracking-tight mb-8">
            <span class="text-ink">The integration<br />layer </span><span class="italic text-teal">for&nbsp;agents</span>
          </h1>

          <p class="rise-d2 text-[17px] leading-[1.7] text-ink-muted max-w-md mb-10">
            One catalog. Every agent. Shared auth, policies, and tools across
            Cursor, Claude Code, OpenCode&mdash;or your own.
          </p>

          <div class="rise-d3 flex flex-wrap items-center gap-4">
            <a href="https://github.com/RhysSullivan/executor" class="inline-flex items-center gap-2 text-[14px] font-medium text-surface bg-teal hover:bg-teal-dim px-5 py-2.5 rounded-md transition-colors">
              Get started
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </a>
            <a href="#how-it-works" class="inline-flex items-center gap-2 text-[14px] text-ink-muted hover:text-ink border border-rule hover:border-ink-faint px-5 py-2.5 rounded-md transition-colors">
              How it works
            </a>
          </div>
        </div>

        <div class="rise-d4 relative">
          <div class="absolute -inset-px rounded-xl bg-gradient-to-b from-teal/10 via-transparent to-transparent pointer-events-none"></div>
          <div class="relative bg-surface-raised border border-rule rounded-xl overflow-hidden">
            <div class="flex items-center justify-between px-4 py-3 border-b border-rule">
              <div class="flex items-center gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full bg-ink-faint/40"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-ink-faint/40"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-ink-faint/40"></div>
              </div>
              <span class="text-[11px] font-mono text-ink-faint">agent.ts</span>
            </div>
            <div class="p-5 font-mono text-[13px] leading-[1.8]">
              <pre set:html={heroCode} />
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-ink-faint">
      <span class="text-[10px] font-mono uppercase tracking-[0.2em]">Scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-ink-faint/60 to-transparent"></div>
    </div>
  </section>

  <!-- ─── THE EVOLUTION: VISUAL DIAGRAM ─── -->
  <section class="py-32 sm:py-40 relative">
    <div class="max-w-[1200px] mx-auto px-6 sm:px-10">
      <div class="reveal mb-20">
        <span class="text-[11px] font-mono uppercase tracking-[0.2em] text-ink-faint mb-4 block">The problem</span>
        <h2 class="font-display text-[clamp(2rem,4.5vw,3.5rem)] leading-[1.05] tracking-tight">
          Agents got smarter.<br /><span class="italic text-ink-muted">Their tooling didn't.</span>
        </h2>
      </div>

      <!-- Visual evolution: 3 columns showing the architecture change -->
      <div class="reveal grid md:grid-cols-3 gap-6 md:gap-4">

        <!-- Era 1: Direct tool calls -->
        <div class="rounded-xl border border-rule bg-surface-raised p-6 sm:p-8 flex flex-col">
          <span class="font-mono text-[11px] text-ink-faint uppercase tracking-[0.15em] mb-6">Era 1 &middot; Tool calling</span>

          <!-- Diagram -->
          <div class="flex-1 flex flex-col items-center gap-3 my-6">
            <div class="w-full rounded-lg border border-rule bg-surface px-4 py-3 text-center text-[13px] font-mono text-ink">Agent</div>
            <!-- Fan-out arrows -->
            <svg class="w-full h-12 text-red-400/50" viewBox="0 0 200 48" fill="none" stroke="currentColor" stroke-width="1.5">
              <line x1="100" y1="0" x2="20" y2="48" />
              <line x1="100" y1="0" x2="60" y2="48" />
              <line x1="100" y1="0" x2="100" y2="48" />
              <line x1="100" y1="0" x2="140" y2="48" />
              <line x1="100" y1="0" x2="180" y2="48" />
            </svg>
            <div class="w-full grid grid-cols-5 gap-1">
              <div class="rounded border border-red-400/20 bg-red-400/5 px-1 py-2 text-center text-[9px] font-mono text-red-400/60">tool</div>
              <div class="rounded border border-red-400/20 bg-red-400/5 px-1 py-2 text-center text-[9px] font-mono text-red-400/60">tool</div>
              <div class="rounded border border-red-400/20 bg-red-400/5 px-1 py-2 text-center text-[9px] font-mono text-red-400/60">tool</div>
              <div class="rounded border border-red-400/20 bg-red-400/5 px-1 py-2 text-center text-[9px] font-mono text-red-400/60">tool</div>
              <div class="rounded border border-red-400/20 bg-red-400/5 px-1 py-2 text-center text-[9px] font-mono text-red-400/60">tool</div>
            </div>
          </div>

          <p class="text-[13px] text-ink-faint mt-auto">Every schema dumped into context. Tokens wasted. Poor performance.</p>
        </div>

        <!-- Era 2: Bash -->
        <div class="rounded-xl border border-rule bg-surface-raised p-6 sm:p-8 flex flex-col">
          <span class="font-mono text-[11px] text-ink-faint uppercase tracking-[0.15em] mb-6">Era 2 &middot; Bash</span>

          <div class="flex-1 flex flex-col items-center gap-3 my-6">
            <div class="w-full rounded-lg border border-rule bg-surface px-4 py-3 text-center text-[13px] font-mono text-ink">Agent</div>
            <svg class="w-full h-8 text-amber-400/50" viewBox="0 0 200 32" fill="none" stroke="currentColor" stroke-width="1.5">
              <line x1="100" y1="0" x2="100" y2="32" />
            </svg>
            <div class="w-full rounded-lg border border-amber-400/30 bg-amber-400/5 px-4 py-3 text-center text-[13px] font-mono text-amber-400/80">bash</div>
            <svg class="w-full h-8 text-amber-400/50" viewBox="0 0 200 32" fill="none" stroke="currentColor" stroke-width="1.5">
              <line x1="60" y1="0" x2="20" y2="32" />
              <line x1="100" y1="0" x2="100" y2="32" />
              <line x1="140" y1="0" x2="180" y2="32" />
            </svg>
            <div class="w-full grid grid-cols-3 gap-1.5">
              <div class="rounded border border-amber-400/20 bg-amber-400/5 px-1 py-2 text-center text-[9px] font-mono text-amber-400/60">CLI</div>
              <div class="rounded border border-amber-400/20 bg-amber-400/5 px-1 py-2 text-center text-[9px] font-mono text-amber-400/60">CLI</div>
              <div class="rounded border border-amber-400/20 bg-amber-400/5 px-1 py-2 text-center text-[9px] font-mono text-amber-400/60">CLI</div>
            </div>
          </div>

          <p class="text-[13px] text-ink-faint mt-auto">Better, but no permissions, no shared auth, a CLI for every API.</p>
        </div>

        <!-- Era 3: Executor -->
        <div class="rounded-xl border border-teal/20 bg-surface-raised p-6 sm:p-8 flex flex-col relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-b from-teal/[0.03] to-transparent pointer-events-none"></div>
          <span class="relative font-mono text-[11px] text-teal uppercase tracking-[0.15em] mb-6">Era 3 &middot; Executor</span>

          <div class="relative flex-1 flex flex-col items-center gap-3 my-6">
            <!-- Multiple agents -->
            <div class="w-full grid grid-cols-3 gap-1.5">
              <div class="rounded-lg border border-rule bg-surface px-2 py-2.5 text-center text-[10px] font-mono text-ink">Cursor</div>
              <div class="rounded-lg border border-rule bg-surface px-2 py-2.5 text-center text-[10px] font-mono text-ink">Claude</div>
              <div class="rounded-lg border border-rule bg-surface px-2 py-2.5 text-center text-[10px] font-mono text-ink">Custom</div>
            </div>
            <svg class="w-full h-8 text-teal/50" viewBox="0 0 200 32" fill="none" stroke="currentColor" stroke-width="1.5">
              <line x1="33" y1="0" x2="100" y2="32" />
              <line x1="100" y1="0" x2="100" y2="32" />
              <line x1="167" y1="0" x2="100" y2="32" />
            </svg>
            <!-- Executor box with features -->
            <div class="w-full rounded-lg border border-teal/30 bg-teal/[0.06] px-4 py-3">
              <div class="text-center text-[13px] font-mono text-teal mb-2">executor</div>
              <div class="flex justify-center gap-2">
                <span class="text-[9px] font-mono text-teal/60 border border-teal/15 rounded px-1.5 py-0.5">auth</span>
                <span class="text-[9px] font-mono text-teal/60 border border-teal/15 rounded px-1.5 py-0.5">policies</span>
                <span class="text-[9px] font-mono text-teal/60 border border-teal/15 rounded px-1.5 py-0.5">catalog</span>
              </div>
            </div>
            <svg class="w-full h-8 text-teal/50" viewBox="0 0 200 32" fill="none" stroke="currentColor" stroke-width="1.5">
              <line x1="50" y1="0" x2="25" y2="32" />
              <line x1="83" y1="0" x2="75" y2="32" />
              <line x1="117" y1="0" x2="125" y2="32" />
              <line x1="150" y1="0" x2="175" y2="32" />
            </svg>
            <div class="w-full grid grid-cols-4 gap-1">
              <div class="rounded border border-teal/20 bg-teal/5 px-1 py-2 text-center text-[8px] font-mono text-teal/60">OpenAPI</div>
              <div class="rounded border border-teal/20 bg-teal/5 px-1 py-2 text-center text-[8px] font-mono text-teal/60">GraphQL</div>
              <div class="rounded border border-teal/20 bg-teal/5 px-1 py-2 text-center text-[8px] font-mono text-teal/60">MCP</div>
              <div class="rounded border border-teal/20 bg-teal/5 px-1 py-2 text-center text-[8px] font-mono text-teal/60">Google</div>
            </div>
          </div>

          <p class="relative text-[13px] text-teal/70 mt-auto">Typed, sandboxed, shared across all agents.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── WHAT YOU GET: icon grid ─── -->
  <section class="py-32 sm:py-40 relative">
    <div class="absolute inset-0 border-t border-b border-rule"></div>

    <div class="relative max-w-[1200px] mx-auto px-6 sm:px-10">
      <div class="reveal mb-16">
        <span class="text-[11px] font-mono uppercase tracking-[0.2em] text-ink-faint mb-4 block">The stack</span>
        <h2 class="font-display text-[clamp(2rem,4.5vw,3.5rem)] leading-[1.05] tracking-tight">
          Everything in<br /><span class="italic text-teal">one place</span>
        </h2>
      </div>

      <div class="reveal grid sm:grid-cols-2 lg:grid-cols-3 gap-px bg-rule rounded-xl overflow-hidden">
        <div class="bg-surface p-8">
          <svg class="w-6 h-6 text-teal mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" /></svg>
          <div class="text-[14px] font-medium mb-1">Unified catalog</div>
          <p class="text-[13px] text-ink-muted">OpenAPI, GraphQL, MCP, Google Discovery. All indexed.</p>
        </div>
        <div class="bg-surface p-8">
          <svg class="w-6 h-6 text-teal mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z" /></svg>
          <div class="text-[14px] font-medium mb-1">Shared auth</div>
          <p class="text-[13px] text-ink-muted">Sign in once. Every agent shares your credentials.</p>
        </div>
        <div class="bg-surface p-8">
          <svg class="w-6 h-6 text-teal mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
          <div class="text-[14px] font-medium mb-1">Policies</div>
          <p class="text-[13px] text-ink-muted">Auto-approve reads. Pause on writes. Wildcard rules.</p>
        </div>
        <div class="bg-surface p-8">
          <svg class="w-6 h-6 text-teal mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" /></svg>
          <div class="text-[14px] font-medium mb-1">Any agent via MCP</div>
          <p class="text-[13px] text-ink-muted">Executor is an MCP server. Point any agent at it.</p>
        </div>
        <div class="bg-surface p-8">
          <svg class="w-6 h-6 text-teal mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>
          <div class="text-[14px] font-medium mb-1">Local-first</div>
          <p class="text-[13px] text-ink-muted">Secrets in your keychain. Nothing leaves your machine.</p>
        </div>
        <div class="bg-surface p-8">
          <svg class="w-6 h-6 text-teal mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" /></svg>
          <div class="text-[14px] font-medium mb-1">Intent-based discovery</div>
          <p class="text-[13px] text-ink-muted">Agents search by what they need, not memorized paths.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── HOW IT WORKS: compact ─── -->
  <section id="how-it-works" class="py-32 sm:py-40 relative">
    <div class="max-w-[1200px] mx-auto px-6 sm:px-10">
      <div class="reveal mb-20">
        <span class="text-[11px] font-mono uppercase tracking-[0.2em] text-ink-faint mb-4 block">How it works</span>
        <h2 class="font-display text-[clamp(2rem,4.5vw,3.5rem)] leading-[1.05] tracking-tight">
          Four steps to<br /><span class="italic text-teal">every integration</span>
        </h2>
      </div>

      <!-- Horizontal steps on desktop -->
      <div class="reveal grid md:grid-cols-4 gap-px bg-rule rounded-xl overflow-hidden mb-16">
        <div class="bg-surface p-6 sm:p-8">
          <span class="font-display text-4xl text-teal/20 leading-none block mb-4">1</span>
          <h3 class="text-[14px] font-medium mb-2">Add sources</h3>
          <p class="text-[13px] text-ink-muted">Point at any OpenAPI, GraphQL, MCP, or Google Discovery endpoint.</p>
        </div>
        <div class="bg-surface p-6 sm:p-8">
          <span class="font-display text-4xl text-teal/20 leading-none block mb-4">2</span>
          <h3 class="text-[14px] font-medium mb-2">Tools are indexed</h3>
          <p class="text-[13px] text-ink-muted">Every endpoint becomes a typed, discoverable tool in your catalog.</p>
        </div>
        <div class="bg-surface p-6 sm:p-8">
          <span class="font-display text-4xl text-teal/20 leading-none block mb-4">3</span>
          <h3 class="text-[14px] font-medium mb-2">Set policies</h3>
          <p class="text-[13px] text-ink-muted">Define what's auto-approved and what needs human sign-off.</p>
        </div>
        <div class="bg-surface p-6 sm:p-8">
          <span class="font-display text-4xl text-teal/20 leading-none block mb-4">4</span>
          <h3 class="text-[14px] font-medium mb-2">Connect agents</h3>
          <p class="text-[13px] text-ink-muted">Expose your catalog over MCP. Any agent gets your tools and auth.</p>
        </div>
      </div>

      <!-- Single code block showing the MCP bridge -->
      <div class="reveal max-w-lg mx-auto">
        <div class="bg-surface-raised border border-rule rounded-lg overflow-hidden">
          <div class="px-4 py-2.5 border-b border-rule">
            <span class="text-[11px] font-mono text-ink-faint">terminal</span>
          </div>
          <div class="p-5 font-mono text-[13px] leading-[1.8]">
            <pre set:html={mcpCode} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── SOURCES: visual strip ─── -->
  <section class="py-20 relative">
    <div class="absolute inset-0 border-t border-b border-rule"></div>

    <div class="relative max-w-[1200px] mx-auto px-6 sm:px-10">
      <div class="flex flex-wrap items-center justify-between gap-6">
        <span class="text-[13px] text-ink-muted">If it has a schema, it's a source</span>
        <div class="flex items-center gap-8 sm:gap-12">
          <span class="font-mono text-[14px] text-teal font-medium">OpenAPI</span>
          <span class="font-mono text-[14px] text-teal font-medium">GraphQL</span>
          <span class="font-mono text-[14px] text-teal font-medium">MCP</span>
          <span class="font-mono text-[14px] text-teal font-medium">Google Discovery</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── ROADMAP ─── -->
  <section id="roadmap" class="py-32 sm:py-40 relative">
    <div class="max-w-[1200px] mx-auto px-6 sm:px-10">
      <div class="reveal mb-16">
        <span class="text-[11px] font-mono uppercase tracking-[0.2em] text-ink-faint mb-4 block">Roadmap</span>
        <h2 class="font-display text-[clamp(2rem,4.5vw,3.5rem)] leading-[1.05] tracking-tight">
          What's <span class="italic text-teal">next</span>
        </h2>
      </div>

      <div class="reveal grid md:grid-cols-3 gap-6">
        <!-- Now -->
        <div class="rounded-xl border border-teal/20 p-6 sm:p-8 relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-b from-teal/[0.03] to-transparent pointer-events-none"></div>
          <div class="relative">
            <div class="flex items-center gap-2 mb-5">
              <div class="w-2 h-2 rounded-full bg-teal shadow-[0_0_6px_rgba(61,216,181,0.4)]"></div>
              <span class="font-mono text-[11px] text-teal uppercase tracking-[0.15em]">Now</span>
            </div>
            <ul class="space-y-3 text-[14px]">
              <li class="flex items-start gap-2.5">
                <svg class="w-4 h-4 text-teal mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
