---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Executor — The unified tool catalog for AI agents" description="Stop making everyone on your team set up their own agent integrations. Connect your services to Executor once, and give every agent in your organization safe, authenticated access to your entire stack.">
  <main class="bg-zinc-950 text-zinc-50 min-h-screen selection:bg-zinc-800 selection:text-white">
    
    {/* NAVIGATION */}
    <nav class="fixed top-0 inset-x-0 z-50 bg-zinc-950/80 backdrop-blur-md border-b border-zinc-900">
      <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
        <div class="flex items-center gap-2 font-mono font-semibold text-lg tracking-tight">
          <div class="w-5 h-5 rounded bg-white"></div>
          Executor
        </div>
        <div class="hidden md:flex items-center gap-8 text-sm font-medium text-zinc-400">
          <a href="/docs" class="hover:text-white transition-colors">Docs</a>
          <a href="/pricing" class="hover:text-white transition-colors">Pricing</a>
          <a href="https://github.com/executor-js/executor" class="hover:text-white transition-colors">GitHub ⭐</a>
        </div>
        <div class="flex items-center gap-4">
          <a href="/docs" class="bg-white text-black px-4 py-2 rounded-md text-sm font-semibold hover:bg-zinc-200 transition-colors">Get Started</a>
        </div>
      </div>
    </nav>

    {/* 1. THE HERO */}
    <section class="pt-40 pb-20 px-6 overflow-hidden">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-8 font-serif">
          The unified tool catalog <br class="hidden md:block"/> for AI agents.
        </h1>
        <p class="text-xl md:text-2xl text-zinc-400 max-w-3xl mx-auto leading-relaxed font-sans mb-12">
          Stop making everyone on your team set up their own agent integrations. Connect your services to Executor once, and give every agent in your organization safe, authenticated access to your entire stack.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/docs" class="bg-white text-black px-8 py-3 rounded-lg text-base font-semibold hover:bg-zinc-200 transition-colors w-full sm:w-auto">
            Get Started
          </a>
          <div class="flex items-center bg-zinc-900 border border-zinc-800 px-6 py-3 rounded-lg text-zinc-300 font-mono text-sm w-full sm:w-auto">
            <span class="text-zinc-500 mr-3">~</span>
            npx create-executor-app
          </div>
        </div>
      </div>

      {/* Hero Visual: 3-Column Diagram */}
      <div class="max-w-6xl mx-auto mt-24 relative">
        <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-transparent to-transparent z-10 h-full w-full pointer-events-none"></div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 relative z-0">
          
          {/* Left: Sources */}
          <div class="bg-zinc-900/50 border border-zinc-800 rounded-xl p-6 flex flex-col gap-4">
            <div class="text-xs font-mono text-zinc-500 uppercase tracking-widest mb-2">Sources In</div>
            <div class="bg-zinc-950 border border-zinc-800 rounded-lg p-3 flex items-center gap-3">
              <div class="w-6 h-6 rounded-full bg-blue-500/20 flex items-center justify-center text-blue-400 text-xs">S</div>
              <span class="text-sm font-medium">Sentry (OpenAPI)</span>
            </div>
            <div class="bg-zinc-950 border border-zinc-800 rounded-lg p-3 flex items-center gap-3">
              <div class="w-6 h-6 rounded-full bg-zinc-700/20 flex items-center justify-center text-zinc-300 text-xs">G</div>
              <span class="text-sm font-medium">GitHub (GraphQL)</span>
            </div>
            <div class="bg-zinc-950 border border-zinc-800 rounded-lg p-3 flex items-center gap-3">
              <div class="w-6 h-6 rounded-full bg-indigo-500/20 flex items-center justify-center text-indigo-400 text-xs">L</div>
              <span class="text-sm font-medium">Linear (MCP)</span>
            </div>
          </div>

          {/* Middle: Executor */}
          <div class="bg-zinc-900 border border-zinc-700 rounded-xl p-6 flex flex-col items-center justify-center text-center relative shadow-2xl shadow-zinc-900">
            <div class="absolute -left-3 top-1/2 -translate-y-1/2 w-6 h-[1px] bg-zinc-700 hidden md:block"></div>
            <div class="absolute -right-3 top-1/2 -translate-y-1/2 w-6 h-[1px] bg-zinc-700 hidden md:block"></div>
            
            <div class="w-16 h-16 rounded-xl bg-white shadow-lg flex items-center justify-center mb-6">
              <div class="w-8 h-8 rounded bg-black"></div>
            </div>
            <h3 class="font-bold text-xl text-white mb-2">Executor Hub</h3>
            <p class="text-sm text-zinc-400">Unified Catalog &<br/>Auth Proxy</p>
          </div>

          {/* Right: Agents */}
          <div class="bg-zinc-900/50 border border-zinc-800 rounded-xl p-6 flex flex-col gap-4">
            <div class="text-xs font-mono text-zinc-500 uppercase tracking-widest mb-2">Agents Out</div>
            <div class="bg-zinc-950 border border-zinc-800 rounded-lg p-3 flex items-center gap-3">
              <div class="w-6 h-6 rounded-md bg-orange-500/20 flex items-center justify-center text-orange-400 text-xs">C</div>
              <span class="text-sm font-medium">Claude Desktop</span>
            </div>
            <div class="bg-zinc-950 border border-zinc-800 rounded-lg p-3 flex items-center gap-3">
              <div class="w-6 h-6 rounded-md bg-zinc-100 flex items-center justify-center text-black text-xs font-serif">C</div>
              <span class="text-sm font-medium">Cursor</span>
            </div>
            <div class="bg-zinc-950 border border-zinc-800 rounded-lg p-3 flex items-center gap-3">
              <div class="w-6 h-6 rounded-md bg-green-500/20 flex items-center justify-center text-green-400 text-xs font-mono">{`>_`}</div>
              <span class="text-sm font-medium">Custom CI Scripts</span>
            </div>
          </div>
          
        </div>
      </div>
    </section>

    {/* Divider */}
    <div class="max-w-6xl mx-auto px-6"><div class="h-px bg-zinc-900 w-full"></div></div>

    {/* 2. THE CORE PAIN POINT */}
    <section class="py-32 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight mb-8 font-serif">End the integration Groundhog Day.</h2>
        <p class="text-xl text-zinc-400 leading-relaxed font-sans">
          Right now, every time a developer wants their agent to talk to Jira or AWS, they have to configure it locally. When you switch to a new agent, you have to do it all over again. Executor centralizes your tools. You expose your APIs and specs in one place, and the capabilities are instantly synced and shared across every agent your team uses.
        </p>
      </div>
    </section>

    {/* 3. CONTEXT & SCALE */}
    <section class="py-32 px-6 bg-zinc-900/20 border-y border-zinc-900">
      <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-6 font-serif">Infinite capabilities.<br/>Zero context bloat.</h2>
          <p class="text-lg text-zinc-400 leading-relaxed">
            Feeding thousands of tool descriptions into an agent destroys its context window and ruins reasoning. Executor solves this. No matter how massive your tool catalog gets, Executor intelligently routes and exposes only what the agent needs, when it needs it. You get the power of 10,000 tools without degrading your agent's performance.
          </p>
        </div>
        <div class="bg-zinc-950 border border-zinc-800 rounded-xl p-6 font-mono text-sm text-zinc-300 shadow-xl overflow-hidden relative">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue-500 to-indigo-500"></div>
          <div class="text-zinc-500 mb-4">// Executor exposes one tool: execute</div>
          <div class="text-purple-400">await</div> <div class="inline">executor.search(</div><div class="text-green-400 inline">'*aws*rds*'</div><div class="inline">)</div>
          <br/><br/>
          <div class="text-zinc-500 mb-2">// Agent runs code in a sandbox</div>
          <div class="text-purple-400">const</div> <div class="inline">db = tools.aws.rds.describeDBInstances()</div>
          <br/>
          <div class="text-purple-400">if</div> <div class="inline">(db.status ===</div> <div class="text-green-400 inline">'stopped'</div><div class="inline">) {'{'}</div>
          <br/>
          &nbsp;&nbsp;<div class="text-purple-400">await</div> <div class="inline">tools.slack.notify({'...'})</div>
          <br/>
          <div class="inline">{'}'}</div>
        </div>
      </div>
    </section>

    {/* 4. INTERACTIVE POLICIES */}
    <section class="py-32 px-6 overflow-hidden">
      <div class="max-w-6xl mx-auto">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-3xl md:text-5xl font-bold tracking-tight mb-6 font-serif">Trust your agents to work.<br/>Never trust them with the keys.</h2>
          <p class="text-lg text-zinc-400 leading-relaxed">
            Give your agents access to production, safely. Executor’s policy engine lets you define exactly what happens when an agent tries to take action. Auto-approve safe queries, strictly block destructive actions, or require human-in-the-loop approval before an agent drops a database or refunds a charge.
          </p>
        </div>

        {/* Interactive Demo UI */}
        <div class="max-w-4xl mx-auto bg-zinc-900 border border-zinc-800 rounded-2xl shadow-2xl overflow-hidden" id="policy-demo">
          <div class="border-b border-zinc-800 p-4 flex items-center justify-between bg-zinc-950">
            <div class="flex gap-2">
              <div class="w-3 h-3 rounded-full bg-zinc-800"></div>
              <div class="w-3 h-3 rounded-full bg-zinc-800"></div>
              <div class="w-3 h-3 rounded-full bg-zinc-800"></div>
            </div>
            <div class="text-xs font-mono text-zinc-500">executor-policy-engine</div>
            <div></div>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-3">
            {/* Sidebar Controls */}
            <div class="col-span-1 border-r border-zinc-800 bg-zinc-950/50 p-6 flex flex-col gap-4">
              <div class="text-xs font-bold tracking-wider text-zinc-500 uppercase mb-2">Select Policy</div>
              
              <button class="policy-btn active flex flex-col items-start p-3 rounded-lg border border-zinc-700 bg-zinc-800 text-left transition-all" data-policy="approve">
                <span class="text-sm font-bold text-green-400 mb-1 flex items-center gap-2">
                  <span class="w-2 h-2 rounded-full bg-green-400"></span> Auto-Approve
                </span>
                <span class="text-xs text-zinc-400">Safe read-only actions.</span>
              </button>

              <button class="policy-btn flex flex-col items-start p-3 rounded-lg border border-zinc-800 hover:border-zinc-700 text-left transition-all" data-policy="block">
                <span class="text-sm font-bold text-red-400 mb-1 flex items-center gap-2">
                  <span class="w-2 h-2 rounded-full bg-red-400"></span> Block
                </span>
                <span class="text-xs text-zinc-400">Highly destructive actions.</span>
              </button>

              <button class="policy-btn flex flex-col items-start p-3 rounded-lg border border-zinc-800 hover:border-zinc-700 text-left transition-all" data-policy="human">
                <span class="text-sm font-bold text-yellow-400 mb-1 flex items-center gap-2">
                  <span class="w-2 h-2 rounded-full bg-yellow-400"></span> Require Approval
                </span>
                <span class="text-xs text-zinc-400">Pause and ask a human.</span>
              </button>
            </div>

            {/* Execution Viewer */}
            <div class="col-span-2 p-6 bg-zinc-900 flex flex-col justify-center min-h-[300px] relative font-mono text-sm">
              {/* Output: Approve */}
              <div id="output-approve" class="policy-output space-y-4">
                <div class="flex gap-3 text-zinc-400">
                  <span class="text-blue-400">Agent</span>
                  <span>Executing: <span class="text-white">sentry.list_issues()</span></span>
                </div>
                <div class="flex gap-3 text-zinc-400">
                  <span class="text-green-400">Policy</span>
                  <span>Matched rule: <span class="text-white">"sentry.*"</span> -> Allow</span>
                </div>
                <div class="flex gap-3 text-zinc-400">
                  <span class="text-zinc-500">System</span>
                  <span class="text-white bg-zinc-800 px-2 py-1 rounded">✔ Success: Returned 12 issues.</span>
                </div>
              </div>

              {/* Output: Block */}
              <div id="output-block" class="policy-output space-y-4 hidden">
                <div class="flex gap-3 text-zinc-400">
                  <span class="text-blue-400">Agent</span>
                  <span>Executing: <span class="text-white">aws.ec2.terminate_instances()</span></span>
                </div>
                <div class="flex gap-3 text-zinc-400">
                  <span class="text-red-400">Policy</span>
                  <span>Matched rule: <span class="text-white">"aws.ec2.terminate*"</span> -> Block</span>
                </div>
                <div class="flex gap-3 text-zinc-400">
                  <span class="text-zinc-500">System</span>
                  <span class="text-red-400 bg-red-400/10 px-2 py-1 rounded border border-red-400/20">✖ Error: Action explicitly forbidden by organization policy.</span>
                </div>
              </div>

              {/* Output: Human */}
              <div id="output-human" class="policy-output space-y-4 hidden">
                <div class="flex gap-3 text-zinc-400">
                  <span class="text-blue-400">Agent</span>
                  <span>Executing: <span class="text-white">github.repos.delete()</span></span>
                </div>
                <div class="flex gap-3 text-zinc-400">
                  <span class="text-yellow-400">Policy</span>
                  <span>Matched rule: <span class="text-white">"github.*.delete"</span> -> Require Approval</span>
                </div>
                <div class="flex gap-3 text-zinc-400 animate-pulse">
                  <span class="text-zinc-500">System</span>
                  <span class="text-yellow-400">⏸️ Execution paused. Waiting for human approval...</span>
                </div>
                <div class="mt-4 border border-zinc-700 bg-zinc-950 p-4 rounded-lg shadow-xl shadow-black/50 ml-12 animate-fade-in relative">
                  <div class="text-xs text-zinc-500 mb-2">Incoming Approval Request</div>
                  <div class="text-sm text-white mb-4">Agent wants to delete repository: `legacy-api`.</div>
                  <div class="flex gap-3">
                    <button class="px-3 py-1.5 bg-green-500/20 text-green-400 border border-green-500/30 rounded text-xs hover:bg-green-500/30">Approve</button>
                    <button class="px-3 py-1.5 bg-red-500/20 text-red-400 border border-red-500/30 rounded text-xs hover:bg-red-500/30">Deny</button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* 5. FLEXIBLE AUTH */}
    <section class="py-32 px-6 bg-zinc-900/20 border-y border-zinc-900">
      <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
        <div class="order-2 md:order-1 flex flex-col gap-4">
          <div class="bg-zinc-950 border border-zinc-800 rounded-xl p-5 flex items-center justify-between">
            <div>
              <div class="font-medium text-white mb-1">Slack Bot Token</div>
              <div class="text-xs text-zinc-400">Used for read/write to #engineering</div>
            </div>
            <div class="text-xs font-mono bg-blue-500/10 text-blue-400 px-2 py-1 rounded border border-blue-500/20">Org-Level</div>
          </div>
          <div class="bg-zinc-950 border border-zinc-800 rounded-xl p-5 flex items-center justify-between">
            <div>
              <div class="font-medium text-white mb-1">GitHub Personal Access Token</div>
              <div class="text-xs text-zinc-400">Authenticates as the active user</div>
            </div>
            <div class="text-xs font-mono bg-purple-500/10 text-purple-400 px-2 py-1 rounded border border-purple-500/20">Per-User OAuth</div>
          </div>
        </div>
        <div class="order-1 md:order-2">
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-6 font-serif">Centralized auth.<br/>Zero leaked secrets.</h2>
          <p class="text-lg text-zinc-400 leading-relaxed">
            Stop pasting API keys into agent prompts or local env files. Executor acts as a secure authentication proxy. Set global Org-level tokens for shared services, or enforce Per-User OAuth so agents only act with the exact permissions of the human commanding them. The agent never sees the raw keys.
          </p>
        </div>
      </div>
    </section>

    {/* 6. UNIVERSAL COMPATIBILITY */}
    <section class="py-32 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight mb-8 font-serif">Bring your own agent.</h2>
        <p class="text-xl text-zinc-400 leading-relaxed font-sans mb-12">
          Executor speaks the Model Context Protocol (MCP) natively. Whether your team prefers chatting in Claude, coding in Cursor, or building custom agents, connecting them to Executor takes one click. Swap agents whenever you want; your tool catalog stays exactly where it is.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4 text-sm font-medium text-zinc-400">
          <div class="px-4 py-2 border border-zinc-800 rounded-full bg-zinc-900">Cursor</div>
          <div class="px-4 py-2 border border-zinc-800 rounded-full bg-zinc-900">Claude Desktop</div>
          <div class="px-4 py-2 border border-zinc-800 rounded-full bg-zinc-900">ChatGPT</div>
          <div class="px-4 py-2 border border-zinc-800 rounded-full bg-zinc-900">Windsurf</div>
          <div class="px-4 py-2 border border-zinc-800 rounded-full bg-zinc-900">Custom MCP Clients</div>
        </div>
      </div>
    </section>

    {/* 7. BOTTOM CTA */}
    <section class="py-32 px-6 bg-white text-black text-center">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-4xl md:text-6xl font-bold tracking-tight mb-8 font-serif">Where your agents go<br/>to get work done.</h2>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/docs" class="bg-black text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-zinc-800 transition-colors w-full sm:w-auto">
            Get Started
          </a>
          <a href="https://github.com/executor-js/executor" class="bg-zinc-200 text-black px-8 py-4 rounded-lg text-lg font-semibold hover:bg-zinc-300 transition-colors w-full sm:w-auto">
            View Documentation
          </a>
        </div>
      </div>
    </section>

    {/* FOOTER */}
    <footer class="bg-zinc-950 py-12 px-6 border-t border-zinc-900">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
        <div class="flex items-center gap-2 font-mono font-semibold text-lg tracking-tight text-white">
          <div class="w-5 h-5 rounded bg-white"></div>
          Executor
        </div>
        <div class="text-sm text-zinc-500">
          &copy; {new Date().getFullYear()} Executor. All rights reserved.
        </div>
      </div>
    </footer>

  </main>

  <style>
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(5px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in {
      animation: fadeIn 0.3s ease-out forwards;
    }
  </style>

  <script>
    // Interactive Policy Demo Logic
    document.addEventListener('DOMContentLoaded', () => {
      const buttons = document.querySelectorAll('.policy-btn');
      const outputs = document.querySelectorAll('.policy-output');

      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          // Remove active state
          buttons.forEach(b => {
            b.classList.remove('bg-zinc-800', 'border-zinc-700');
            b.classList.add('border-zinc-800');
          });
          
          // Add active state to clicked
          btn.classList.add('bg-zinc-800', 'border-zinc-700');
          btn.classList.remove('border-zinc-800');

          // Hide all outputs
          outputs.forEach(out => out.classList.add('hidden'));

          // Show target output
          const target = btn.getAttribute('data-policy');
          document.getElementById(`output-${target}`).classList.remove('hidden');
        });
      });
    });
  </script>
</Layout>
