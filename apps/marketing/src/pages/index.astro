---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Executor | Unified Catalog" description="Connect your services once, give every agent authenticated access to your stack.">
  <main class="bg-white min-h-screen text-slate-800 font-sans selection:bg-blue-200 selection:text-blue-900 pb-32 overflow-hidden relative">
    
    {/* Architectural Blueprint Background */}
    <div class="absolute inset-0 bg-[linear-gradient(#e2e8f0_1px,transparent_1px),linear-gradient(90deg,#e2e8f0_1px,transparent_1px)] bg-[size:32px_32px] pointer-events-none opacity-50"></div>

    {/* TOP BAR */}
    <nav class="fixed top-0 w-full bg-white/90 backdrop-blur-md border-b border-slate-200 z-50">
      <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
        <div class="flex items-center gap-2 font-bold text-slate-900 tracking-tight">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-blue-600"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="M10 4v4"></path><path d="M2 8h20"></path><path d="M6 4v4"></path></svg>
          Executor
        </div>
        <div class="hidden md:flex items-center gap-8 text-sm font-semibold text-slate-600">
          <a href="/docs" class="hover:text-blue-600 transition-colors">Documentation</a>
          <a href="/pricing" class="hover:text-blue-600 transition-colors">Pricing</a>
          <a href="https://github.com/executor-js/executor" class="hover:text-blue-600 transition-colors">GitHub</a>
        </div>
        <div class="flex items-center gap-4">
          <a href="/docs" class="bg-blue-600 text-white px-5 py-2 rounded-md text-sm font-semibold hover:bg-blue-700 transition-colors shadow-sm">
            Get Started
          </a>
        </div>
      </div>
    </nav>

    {/* HERO & INTERACTIVE BLUEPRINT */}
    <section class="pt-32 pb-20 px-6 relative z-10">
      <div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-12">
        
        <div class="w-full lg:w-5/12">
          <div class="inline-flex border border-blue-200 bg-blue-50 text-blue-700 px-3 py-1 rounded-md text-xs font-bold uppercase tracking-wider mb-6">
            System Architecture
          </div>
          <h1 class="text-5xl sm:text-6xl font-bold tracking-tight mb-6 text-slate-900">
            Wire it once.<br/>
            Route it everywhere.
          </h1>
          <p class="text-lg text-slate-600 leading-relaxed mb-8">
            Click the building blocks on the blueprint to see how Executor centralizes API routing, handles context windows, and securely passes data to your agents.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/docs" class="bg-slate-900 text-white px-6 py-3 rounded-lg font-semibold shadow-md hover:bg-slate-800 transition-colors text-center">Start Wiring</a>
            <div class="px-6 py-3 rounded-lg bg-white border border-slate-200 text-slate-600 font-mono text-sm shadow-sm flex items-center gap-3 justify-center">
              <span class="text-blue-500 font-bold">$</span>
              npx create-executor-app
            </div>
          </div>
        </div>

        {/* INTERACTIVE BLUEPRINT SVG DIAGRAM */}
        <div class="w-full lg:w-7/12 bg-slate-50 border-2 border-slate-200 rounded-2xl shadow-xl p-8 relative">
          <div class="absolute top-4 left-4 text-xs font-mono text-slate-400 font-bold uppercase tracking-widest">FIG 1. Routing Topology</div>
          
          <div class="relative w-full aspect-[4/3] mt-8" id="blueprint-container">
            {/* SVG Connections */}
            <svg class="absolute inset-0 w-full h-full pointer-events-none z-0">
              {/* Dashed background lines */}
              <path d="M 15% 20% L 50% 50%" fill="none" stroke="#cbd5e1" stroke-width="2" stroke-dasharray="4 4" />
              <path d="M 15% 50% L 50% 50%" fill="none" stroke="#cbd5e1" stroke-width="2" stroke-dasharray="4 4" />
              <path d="M 15% 80% L 50% 50%" fill="none" stroke="#cbd5e1" stroke-width="2" stroke-dasharray="4 4" />
              <path d="M 50% 50% L 85% 35%" fill="none" stroke="#cbd5e1" stroke-width="2" stroke-dasharray="4 4" />
              <path d="M 50% 50% L 85% 65%" fill="none" stroke="#cbd5e1" stroke-width="2" stroke-dasharray="4 4" />
              
              {/* Solid active line (drawn by JS) */}
              <path d="" fill="none" stroke="#2563eb" stroke-width="3" id="active-line" class="transition-all duration-300" />
            </svg>

            {/* Nodes */}
            <button class="bp-node absolute top-[20%] left-[15%] -translate-x-1/2 -translate-y-1/2 w-24 h-16 bg-white border-2 border-slate-300 rounded-lg shadow-sm flex flex-col items-center justify-center cursor-pointer hover:border-blue-500 hover:shadow-md transition-all z-10 group" data-type="source" data-id="1">
              <span class="font-bold text-sm text-slate-800 group-hover:text-blue-600">Sentry</span>
              <span class="text-[10px] text-slate-500 font-mono">OpenAPI</span>
            </button>
            <button class="bp-node absolute top-[50%] left-[15%] -translate-x-1/2 -translate-y-1/2 w-24 h-16 bg-white border-2 border-slate-300 rounded-lg shadow-sm flex flex-col items-center justify-center cursor-pointer hover:border-blue-500 hover:shadow-md transition-all z-10 group" data-type="source" data-id="2">
              <span class="font-bold text-sm text-slate-800 group-hover:text-blue-600">GitHub</span>
              <span class="text-[10px] text-slate-500 font-mono">GraphQL</span>
            </button>
            <button class="bp-node absolute top-[80%] left-[15%] -translate-x-1/2 -translate-y-1/2 w-24 h-16 bg-white border-2 border-slate-300 rounded-lg shadow-sm flex flex-col items-center justify-center cursor-pointer hover:border-blue-500 hover:shadow-md transition-all z-10 group" data-type="source" data-id="3">
              <span class="font-bold text-sm text-slate-800 group-hover:text-blue-600">Linear</span>
              <span class="text-[10px] text-slate-500 font-mono">MCP</span>
            </button>

            {/* Central Hub */}
            <div class="absolute top-[50%] left-[50%] -translate-x-1/2 -translate-y-1/2 w-32 h-32 bg-blue-600 rounded-2xl shadow-xl shadow-blue-600/30 flex flex-col items-center justify-center z-20 text-white transition-transform duration-300" id="bp-hub">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="mb-2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              <span class="font-bold">Executor Hub</span>
            </div>

            {/* Agents */}
            <div class="absolute top-[35%] left-[85%] -translate-x-1/2 -translate-y-1/2 w-24 h-16 bg-white border-2 border-slate-300 rounded-lg shadow-sm flex flex-col items-center justify-center z-10 opacity-50 transition-opacity" id="bp-agent-1">
              <span class="font-bold text-sm text-slate-800">Claude</span>
              <span class="text-[10px] text-slate-500 font-mono">Desktop</span>
            </div>
            <div class="absolute top-[65%] left-[85%] -translate-x-1/2 -translate-y-1/2 w-24 h-16 bg-white border-2 border-slate-300 rounded-lg shadow-sm flex flex-col items-center justify-center z-10 opacity-50 transition-opacity" id="bp-agent-2">
              <span class="font-bold text-sm text-slate-800">Cursor</span>
              <span class="text-[10px] text-slate-500 font-mono">IDE</span>
            </div>

            {/* Information Popover */}
            <div class="absolute bottom-4 right-4 left-4 bg-white/90 backdrop-blur border border-slate-200 p-4 rounded-xl shadow-lg opacity-100 transition-opacity duration-300 z-30 font-mono text-sm" id="bp-info">
              Select a source node to simulate routing.
            </div>
          </div>
        </div>

      </div>
    </section>

    {/* CONTEXT BLOAT & CODE */}
    <section class="py-24 px-6 relative z-10">
      <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-4xl font-bold tracking-tight mb-6 text-slate-900">
            Infinite catalog.<br/>Zero context bloat.
          </h2>
          <p class="text-lg text-slate-600 leading-relaxed mb-8">
            Feeding thousands of tool descriptions into an agent destroys its context window and reasoning. Executor solves this elegantly. No matter how massive your tool catalog gets, Executor selectively routes and exposes only what the agent needs.
          </p>
        </div>
        
        {/* IDE Mockup */}
        <div class="bg-slate-900 rounded-2xl shadow-xl overflow-hidden border border-slate-800">
          <div class="flex items-center gap-2 px-4 py-3 bg-slate-950 border-b border-slate-800">
            <div class="w-3 h-3 rounded-full bg-slate-700"></div>
            <div class="w-3 h-3 rounded-full bg-slate-700"></div>
            <div class="w-3 h-3 rounded-full bg-slate-700"></div>
            <span class="ml-4 text-xs font-mono text-slate-500">sandbox.ts</span>
          </div>
          <div class="p-6 font-mono text-[13px] leading-loose text-slate-300">
            <div class="text-slate-500 mb-2">// Agents execute dynamic discovery in a secure V8 isolate</div>
            <div>
              <span class="text-pink-400">const</span> <span class="text-blue-300">tools</span> <span class="text-pink-400">=</span> <span class="text-purple-400">await</span> <span class="text-white">executor.search</span>(<span class="text-emerald-400">'*aws*rds*'</span>)
            </div>
            <br/>
            <div>
              <span class="text-pink-400">const</span> <span class="text-blue-300">db</span> <span class="text-pink-400">=</span> <span class="text-white">tools.aws.rds.describeDBInstances</span>()
            </div>
            <div>
              <span class="text-purple-400">if</span> (<span class="text-blue-300">db.status</span> <span class="text-pink-400">===</span> <span class="text-emerald-400">'stopped'</span>) {'{'}
            </div>
            <div class="pl-6">
              <span class="text-purple-400">await</span> <span class="text-white">tools.slack.notify</span>({'{'} <span class="text-blue-300">message:</span> <span class="text-emerald-400">'DB down'</span> {'}'})
            </div>
            <div>{'}'}</div>
          </div>
        </div>
      </div>
    </section>

    {/* AUTH ARCHITECTURE */}
    <section class="py-24 px-6 border-t border-slate-200 relative z-10 bg-slate-50">
      <div class="max-w-6xl mx-auto text-center">
        <h2 class="text-4xl font-bold text-slate-900 mb-6">Centralized auth. Zero leaked secrets.</h2>
        <p class="text-lg text-slate-600 leading-relaxed max-w-2xl mx-auto mb-16">
          Stop pasting API keys into agent prompts or local env files. Executor acts as a secure proxy. Set global Org-level tokens for shared services, or enforce Per-User OAuth so agents only act with your exact permissions.
        </p>
        
        {/* Interactive Exploded View */}
        <div class="relative h-[400px] flex flex-col items-center justify-center group cursor-crosshair">
          {/* Layer 1: App */}
          <div class="absolute top-[20%] w-[400px] h-[100px] bg-white border-2 border-slate-300 rounded-xl shadow-md flex items-center justify-center font-bold text-slate-600 transition-all duration-500 group-hover:-translate-y-12 group-hover:scale-105 z-30">
            Agent Interface (Claude / Cursor)
          </div>
          {/* Layer 2: Auth Proxy */}
          <div class="absolute top-[40%] w-[420px] h-[100px] bg-blue-600 border-2 border-blue-700 rounded-xl shadow-xl shadow-blue-600/20 flex items-center justify-between px-8 font-bold text-white transition-all duration-500 group-hover:scale-105 z-20">
            <span>Executor Auth Proxy</span>
            <span class="text-xs bg-white/20 text-white px-2 py-1 rounded-md backdrop-blur-sm border border-white/20">Token Injector</span>
          </div>
          {/* Layer 3: API */}
          <div class="absolute top-[60%] w-[440px] h-[100px] bg-slate-100 border-2 border-slate-400 rounded-xl shadow-inner flex flex-col items-center justify-center font-bold text-slate-700 transition-all duration-500 group-hover:translate-y-12 group-hover:scale-105 z-10">
            <span>Internal APIs / External Services</span>
            <span class="text-xs font-normal text-slate-500 mt-1">Authenticated Requests Only</span>
          </div>
          <p class="absolute bottom-0 text-slate-500 text-sm font-medium opacity-0 group-hover:opacity-100 transition-opacity duration-500">
            Hover to expand. Tokens never reach the agent—they are securely injected mid-flight.
          </p>
        </div>
      </div>
    </section>

    {/* POLICY ENGINE / SAFETY */}
    <section class="py-24 px-6 border-t border-slate-200 relative z-10 bg-white">
      <div class="max-w-6xl mx-auto flex flex-col lg:flex-row gap-16 items-center">
        <div class="lg:w-1/2">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-100 text-emerald-700 font-semibold text-xs mb-6 border border-emerald-200">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
            Safety First
          </div>
          <h2 class="text-4xl font-bold tracking-tight mb-6 text-slate-900">
            Trust the agent.<br/>Verify the action.
          </h2>
          <p class="text-lg text-slate-600 leading-relaxed mb-8">
            Give your agents access to production, safely. Executor’s policy engine lets you define exactly what happens when an agent tries to take action.
          </p>
          <div class="flex flex-col gap-3">
            <div class="flex items-center gap-4 bg-slate-50 border border-slate-200 p-4 rounded-xl">
              <div class="w-10 h-10 rounded-full bg-emerald-100 border border-emerald-200 flex items-center justify-center text-emerald-600 shrink-0 font-bold">✓</div>
              <div><div class="font-bold text-slate-900">Auto-Approve</div><div class="text-sm text-slate-500">For safe read-only queries</div></div>
            </div>
            <div class="flex items-center gap-4 bg-slate-50 border border-slate-200 p-4 rounded-xl">
              <div class="w-10 h-10 rounded-full bg-rose-100 border border-rose-200 flex items-center justify-center text-rose-600 shrink-0 font-bold">✕</div>
              <div><div class="font-bold text-slate-900">Hard Block</div><div class="text-sm text-slate-500">For dangerous destructive actions</div></div>
            </div>
            <div class="flex items-center gap-4 bg-slate-50 border border-slate-200 p-4 rounded-xl">
              <div class="w-10 h-10 rounded-full bg-amber-100 border border-amber-200 flex items-center justify-center text-amber-600 shrink-0 font-bold">!</div>
              <div><div class="font-bold text-slate-900">Require Human</div><div class="text-sm text-slate-500">Pause execution and ask for permission via Slack or UI</div></div>
            </div>
          </div>
        </div>
        
        <div class="lg:w-1/2 w-full relative">
          <div class="bg-slate-900 rounded-2xl p-6 shadow-xl border border-slate-800 font-mono text-sm overflow-hidden text-slate-300">
            <div class="flex gap-2 mb-6 border-b border-slate-800 pb-4">
              <div class="text-xs font-bold text-slate-500 uppercase tracking-widest">Execution Log</div>
            </div>
            <div class="mb-4">
              <span class="text-blue-400">Agent</span> requests <span class="text-white">github.repos.delete()</span>
            </div>
            <div class="mb-4">
              <span class="text-emerald-400">System</span> Evaluating policy... <span class="text-amber-400">Match: "github.*.delete" -> Elicit</span>
            </div>
            <div class="mb-6 animate-pulse text-amber-400">
              ⏸️ Execution paused. Awaiting human...
            </div>
            <div class="bg-white text-slate-900 p-5 rounded-xl shadow-2xl relative font-sans ml-4 border border-slate-200">
              <div class="absolute top-0 left-0 w-1 h-full bg-amber-400 rounded-l-xl"></div>
              <div class="font-bold text-base mb-1">Approval Request</div>
              <div class="text-slate-600 text-sm mb-4">Agent wants to delete <code class="bg-slate-100 px-1 rounded border border-slate-200 text-rose-600">legacy-api</code></div>
              <div class="flex gap-2">
                <button class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-bold hover:bg-blue-700 transition-colors shadow-sm">Authorize</button>
                <button class="bg-slate-50 border border-slate-200 text-slate-600 px-4 py-2 rounded-lg text-sm font-bold hover:bg-slate-100 transition-colors shadow-sm">Reject</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* BOTTOM CTA */}
    <section class="py-32 px-6 border-t border-slate-200 text-center bg-slate-50 relative z-10">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-4xl sm:text-5xl font-bold tracking-tight text-slate-900 mb-8">
          Ready to supercharge your agents?
        </h2>
        <p class="text-xl text-slate-600 mb-12">
          Executor is open-source and easy to deploy. Start routing your APIs directly to your team's LLM clients today.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/docs" class="bg-blue-600 text-white px-8 py-4 rounded-xl text-lg font-bold shadow-lg shadow-blue-600/30 hover:bg-blue-700 hover:-translate-y-1 transition-all">
            Get Started for Free
          </a>
          <a href="https://github.com/executor-js/executor" class="px-8 py-4 rounded-xl bg-white border border-slate-200 text-slate-700 text-lg font-bold hover:bg-slate-50 transition-colors shadow-sm">
            View on GitHub
          </a>
        </div>
      </div>
    </section>

    <footer class="py-8 px-6 border-t border-slate-200 bg-white text-center text-sm font-medium text-slate-500 relative z-10">
      &copy; {new Date().getFullYear()} Executor. All rights reserved.
    </footer>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const nodes = document.querySelectorAll('.bp-node');
        const activeLine = document.getElementById('active-line') as any;
        const info = document.getElementById('bp-info');
        const hub = document.getElementById('bp-hub');
        const agent1 = document.getElementById('bp-agent-1');
        const agent2 = document.getElementById('bp-agent-2');

        nodes.forEach(node => {
          node.addEventListener('click', () => {
            const id = node.getAttribute('data-id');
            const yPos = id === '1' ? '20%' : id === '2' ? '50%' : '80%';
            const sourceName = node.querySelector('span').textContent;
            
            // Draw line to hub
            activeLine.setAttribute('d', `M 15% ${yPos} L 50% 50%`);
            info.style.opacity = '1';
            info.innerHTML = `<span class="text-blue-600">Event:</span> Incoming schema translation from <strong>${sourceName}</strong>...`;

            // Hub pulse
            hub.classList.add('scale-110');
            setTimeout(() => hub.classList.remove('scale-110'), 200);

            setTimeout(() => {
              const agentId = Math.random() > 0.5 ? 1 : 2;
              const agentY = agentId === 1 ? '35%' : '65%';
              const targetAgent = agentId === 1 ? agent1 : agent2;
              const agentName = targetAgent.querySelector('span').textContent;
              
              // Extend line to agent
              activeLine.setAttribute('d', `M 15% ${yPos} L 50% 50% L 85% ${agentY}`);
              info.innerHTML = `<span class="text-emerald-600">Success:</span> Payload securely delivered to <strong>${agentName}</strong>.`;
              
              targetAgent.classList.remove('opacity-50');
              targetAgent.classList.add('border-blue-500', 'ring-4', 'ring-blue-500/20');
              
              setTimeout(() => {
                activeLine.setAttribute('d', '');
                targetAgent.classList.add('opacity-50');
                targetAgent.classList.remove('border-blue-500', 'ring-4', 'ring-blue-500/20');
              }, 1500);
            }, 500);
          });
        });
      });
    </script>
  </main>
</Layout>
