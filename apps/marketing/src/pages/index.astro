  <script>
    // Package manager tabs
    const cmds: Record<string, string> = {
      npm: 'npm install -g executor',
      bun: 'bun add -g executor',
      pnpm: 'pnpm add -g executor',
    };
    const tabs = document.querySelectorAll<HTMLButtonElement>('.pm-tab');
    const cmdText = document.querySelector('.cmd-text');
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => {
          t.classList.remove('pm-tab-active', 'text-teal', 'border-teal');
          t.classList.add('border-transparent', 'text-ink-faint');
        });
        tab.classList.add('pm-tab-active', 'text-teal', 'border-teal');
        tab.classList.remove('border-transparent', 'text-ink-faint');
        if (cmdText) cmdText.textContent = cmds[tab.dataset.pm!] || cmds.npm;
      });
    });
    // Set initial active state
    const initial = document.querySelector('.pm-tab-active');
    if (initial) {
      initial.classList.add('text-teal', 'border-teal');
    }

    // Runner tabs (npx/bunx/pnpx)
    const runnerCmds: Record<string, string> = {
      npx: 'npx add-mcp "executor mcp" --name "executor"',
      bunx: 'bunx add-mcp "executor mcp" --name "executor"',
      pnpx: 'pnpx add-mcp "executor mcp" --name "executor"',
    };
    const runnerTabs = document.querySelectorAll<HTMLButtonElement>('.runner-tab');
    const runnerCmdText = document.querySelector('.runner-cmd-text');
    runnerTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        runnerTabs.forEach(t => {
          t.classList.remove('runner-tab-active', 'text-teal', 'border-teal');
          t.classList.add('border-transparent', 'text-ink-faint');
        });
        tab.classList.add('runner-tab-active', 'text-teal', 'border-teal');
        tab.classList.remove('border-transparent', 'text-ink-faint');
        if (runnerCmdText) runnerCmdText.textContent = runnerCmds[tab.dataset.runner!] || runnerCmds.npx;
      });
    });
    const initialRunner = document.querySelector('.runner-tab-active');
    if (initialRunner) {
      initialRunner.classList.add('text-teal', 'border-teal');
    }

    // Copy buttons
    document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const block = btn.closest('div');
        const cmdEl = block?.querySelector('.cmd-text') || block?.querySelector('.runner-cmd-text') || block?.querySelector('.text-ink');
        const text = cmdEl?.textContent?.trim();
        if (!text) return;
        navigator.clipboard.writeText(text);
        const svg = btn.querySelector('svg')!;
        const orig = svg.innerHTML;
        svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />';
        setTimeout(() => { svg.innerHTML = orig; }, 1500);
      });
    });
  </script>

