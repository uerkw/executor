---
export const prerender = true
import Layout from '../layouts/Layout.astro'
---

<Layout title="Setup Executor" description="Get started with Executor — download the desktop app or install via CLI.">
  <!-- ─── NAV ─── -->
  <nav class="fixed top-0 w-full z-50 bg-surface/80 backdrop-blur-lg">
    <div class="max-w-[1200px] mx-auto px-6 sm:px-10 h-14 flex items-center justify-between border-b border-rule">
      <a href="/" class="font-display text-xl italic text-ink tracking-tight hover:text-teal transition-colors">executor</a>
      <div class="flex items-center gap-8">
        <a href="/setup" class="hidden sm:block text-[13px] text-ink hover:text-ink transition-colors">Setup</a>
        <a href="https://github.com/RhysSullivan/executor" class="hidden sm:block text-[13px] text-ink-muted hover:text-ink transition-colors">GitHub</a>
      </div>
    </div>
  </nav>

  <main class="pt-14">
    <section class="py-24 sm:py-32 relative">
      <div class="absolute top-[20%] left-[50%] -translate-x-1/2 w-[600px] h-[400px] bg-teal/[0.03] rounded-full blur-[150px] pointer-events-none"></div>

      <div class="max-w-[1200px] mx-auto px-6 sm:px-10">
        <div class="text-center max-w-2xl mx-auto mb-16">
          <h1 class="font-display text-[clamp(2.5rem,5vw,4rem)] leading-[1.05] tracking-tight mb-6">
            Get started with <span class="italic text-teal">Executor</span>
          </h1>
          <p class="text-[16px] leading-[1.7] text-ink-muted">
            Manage sources, secrets, and tools from a native desktop app &mdash; or run straight from the command line.
          </p>
        </div>

        <!-- ─── PRIMARY: auto-detected download ─── -->
        <div class="max-w-md mx-auto text-center mb-6" id="primary-download">
          <a id="primary-btn" href="#" class="inline-flex items-center gap-2.5 text-[15px] font-medium text-surface bg-teal hover:bg-teal-dim px-8 py-3.5 rounded-lg transition-colors">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
            <span id="primary-label">Download for macOS</span>
          </a>
          <p class="mt-3 text-[12px] text-ink-faint" id="primary-meta">Apple Silicon &amp; Intel &middot; .dmg</p>
        </div>

        <!-- Other platforms link -->
        <div class="text-center mb-20">
          <button onclick="document.getElementById('all-platforms').classList.toggle('hidden')" class="text-[13px] text-ink-faint hover:text-ink transition-colors underline underline-offset-2 decoration-rule hover:decoration-ink-faint">
            Other platforms
          </button>
        </div>

        <!-- ─── EXPANDED: all platforms (hidden by default) ─── -->
        <div class="hidden max-w-2xl mx-auto mb-20" id="all-platforms">
          <div class="grid sm:grid-cols-3 gap-4">
            <a id="link-mac" href="#" class="group rounded-xl border border-rule hover:border-teal/30 p-5 text-center transition-all">
              <div class="text-[14px] font-medium text-ink mb-1">macOS</div>
              <p class="text-[11px] text-ink-faint">Apple Silicon &amp; Intel &middot; .dmg</p>
            </a>
            <a id="link-win" href="#" class="group rounded-xl border border-rule hover:border-teal/30 p-5 text-center transition-all">
              <div class="text-[14px] font-medium text-ink mb-1">Windows</div>
              <p class="text-[11px] text-ink-faint">Windows 10+ &middot; .exe</p>
            </a>
            <a id="link-linux" href="#" class="group rounded-xl border border-rule hover:border-teal/30 p-5 text-center transition-all">
              <div class="text-[14px] font-medium text-ink mb-1">Linux</div>
              <p class="text-[11px] text-ink-faint">Linux x64 &middot; .AppImage</p>
            </a>
          </div>
        </div>

        <!-- ─── CLI alternative ─── -->
        <div class="max-w-md mx-auto">
          <div class="flex items-center justify-center gap-3 mb-6">
            <div class="h-px flex-1 bg-rule"></div>
            <span class="font-mono text-[11px] text-ink-faint uppercase tracking-[0.15em]">Or via CLI</span>
            <div class="h-px flex-1 bg-rule"></div>
          </div>

          <button onclick="copyCommand('npx executor web')" class="group w-full flex items-center justify-between gap-3 bg-surface-raised border border-rule rounded-lg px-4 py-3 font-mono text-[13px] hover:border-ink-faint transition-colors text-left">
            <div>
              <span class="text-ink-faint select-none">$ </span><span class="text-ink">npx executor web</span>
            </div>
            <svg class="w-4 h-4 text-ink-faint group-hover:text-ink transition-colors shrink-0 copy-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
            <svg class="w-4 h-4 text-teal shrink-0 check-icon hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
          </button>
        </div>
      </div>
    </section>
  </main>

  <!-- ─── FOOTER ─── -->
  <footer class="border-t border-rule py-10">
    <div class="max-w-[1200px] mx-auto px-6 sm:px-10 flex items-center justify-between">
      <span class="font-display italic text-ink-faint text-sm">executor</span>
      <div class="flex items-center gap-5 text-[13px]">
        <a href="/privacy" class="text-ink-faint hover:text-ink transition-colors">Privacy</a>
        <a href="/terms" class="text-ink-faint hover:text-ink transition-colors">Terms</a>
        <a href="https://github.com/RhysSullivan/executor" class="text-ink-faint hover:text-ink transition-colors">GitHub</a>
      </div>
    </div>
  </footer>

  <script is:inline>
    const REPO = 'RhysSullivan/executor';
    const RELEASE_API = `https://api.github.com/repos/${REPO}/releases/latest`;

    const PLATFORMS = {
      mac:   { label: 'Download for macOS',   meta: 'Apple Silicon & Intel \u00b7 .dmg' },
      win:   { label: 'Download for Windows',  meta: 'Windows 10+ \u00b7 .exe' },
      linux: { label: 'Download for Linux',    meta: 'Linux x64 \u00b7 .AppImage' },
    };

    function detectOS() {
      const ua = navigator.userAgent.toLowerCase();
      if (ua.includes('mac')) return 'mac';
      if (ua.includes('win')) return 'win';
      return 'linux';
    }

    async function setup() {
      const userOS = detectOS();
      const platform = PLATFORMS[userOS];

      // Set primary button text immediately
      document.getElementById('primary-label').textContent = platform.label;
      document.getElementById('primary-meta').textContent = platform.meta;

      try {
        const res = await fetch(RELEASE_API);
        if (!res.ok) return;
        const release = await res.json();
        const assets = release.assets || [];

        const find = (pattern) => assets.find(a => pattern.test(a.name));

        // Match: .dmg for macOS (arm64 preferred on Apple Silicon), .exe for Windows, .AppImage for Linux
        const isAppleSilicon = navigator.userAgent.includes('Mac') &&
          (navigator.userAgent.includes('ARM') || navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 0);
        const macAsset = find(isAppleSilicon ? /arm64\.dmg$/ : /x64\.dmg$/) || find(/\.dmg$/);
        const macUrl = macAsset?.browser_download_url;
        const winUrl = find(/\.exe$/)?.browser_download_url;
        const linuxUrl = find(/\.AppImage$/)?.browser_download_url;

        const urls = { mac: macUrl, win: winUrl, linux: linuxUrl };

        // Set primary button to user's OS
        if (urls[userOS]) {
          document.getElementById('primary-btn').href = urls[userOS];
        }

        // Set "other platforms" links
        if (macUrl) document.getElementById('link-mac').href = macUrl;
        if (winUrl) document.getElementById('link-win').href = winUrl;
        if (linuxUrl) document.getElementById('link-linux').href = linuxUrl;
        // If no asset found for user's OS, fall back to releases page
        if (!urls[userOS]) {
          document.getElementById('primary-btn').href = `https://github.com/${REPO}/releases/latest`;
        }
      } catch {
        document.getElementById('primary-btn').href = `https://github.com/${REPO}/releases/latest`;
      }
    }

    function copyCommand(cmd) {
      const btn = event.currentTarget;
      navigator.clipboard.writeText(cmd);
      btn.querySelector('.copy-icon').classList.add('hidden');
      btn.querySelector('.check-icon').classList.remove('hidden');
      setTimeout(() => {
        btn.querySelector('.copy-icon').classList.remove('hidden');
        btn.querySelector('.check-icon').classList.add('hidden');
      }, 1500);
    }

    setup();
  </script>
</Layout>
